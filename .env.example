# Neon Database Configuration
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Gemini API Configuration
GEMINI_API_KEY=your_api_key_here

# Better Auth Configura# Better Auth
BETTER_AUTH_SECRET=your_better_auth_secret_here
BETTER_AUTH_URL=http://localhost:3000

# Neon Auth (Unified SDK)
NEON_AUTH_BASE_URL=https://your-project.neon.tech
NEON_AUTH_COOKIE_SECRET=your-secret-at-least-32-characters-long

# Neon Managed Auth (Legacy/Direct)
NEXT_PUBLIC_NEON_AUTH_URL=https://ep-frosty-bread-aivow338.neonauth.c-4.us-east-1.aws.neon.tech/neondb/auth
NEON_AUTH_JWKS_URL=https://ep-frosty-bread-aivow338.neonauth.c-4.us-east-1.aws.neon.tech/neondb/auth/.well-known/jwks.json
NEON_AUTH_AUDIENCE=your_neon_auth_client_id_here

# Backend URL for Frontend
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Social Logins (Optional) figuration (Optional)
# GITHUB_CLIENT_ID=your_github_client_id
# GITHUB_CLIENT_SECRET=your_github_client_secret
# GOOGLE_CLIENT_ID=your_google_client_id
# GOOGLE_CLIENT_SECRET=your_google_client_secret
